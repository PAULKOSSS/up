<UserControl x:Class="up.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления каталогом: поиск, сортировка, фильтр по жанрам -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBox Width="400" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         ToolTip="Введите название или автора..." Padding="10" FontSize="14"
                         BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}"
                              Width="200" Margin="0,0,30,0" Padding="5"/>
                    <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AvailableGenres}" SelectedItem="{Binding SelectedGenre}"
                              Width="200" Padding="5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Сетка книг с возможностью клика для открытия детальной страницы -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Books}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="200" ItemHeight="320"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White" Margin="10" Padding="10" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding DataContext.OpenBookCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              CommandParameter="{Binding Id}" MouseAction="LeftClick"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <Image Source="{Binding ImageUrl}" Height="200" Stretch="UniformToFill" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40"/>
                                <TextBlock Text="{Binding AuthorName}" Foreground="#6B7280" FontSize="12" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>