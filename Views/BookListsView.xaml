<UserControl x:Class="up.Views.BookListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:up.Infrastructure"
             Background="#F9FAFB">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок раздела -->
            <RowDefinition Height="Auto"/>
            <!-- Панель поиска и фильтров -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки переключения списков -->
            <RowDefinition Height="*"/>
            <!-- Сетка книг -->
        </Grid.RowDefinitions>

        <!-- Динамический заголовок текущего списка -->
        <TextBlock Grid.Row="0" Text="{Binding CurrentSectionTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1F2937"/>

        <!-- Панель управления: поиск, сортировка, фильтр по жанрам -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,15">
            <StackPanel>
                <TextBox Width="350" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         ToolTip="Поиск по названию или автору..." Padding="8" FontSize="13"
                         BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}"
                              Width="180" Margin="0,0,20,0" Padding="4"/>
                    <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding AvailableGenres}" SelectedItem="{Binding SelectedGenre}"
                              Width="180" Padding="4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Кнопки переключения между статусами (Читаю, В планах, Прочитано, Заброшено) -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="📚 Читаю" Command="{Binding SelectReadingCommand}" Width="100" Margin="5" Padding="8,4"/>
            <Button Content="📅 В планах" Command="{Binding SelectPlannedCommand}" Width="100" Margin="5" Padding="8,4"/>
            <Button Content="✅ Прочитано" Command="{Binding SelectReadCommand}" Width="100" Margin="5" Padding="8,4"/>
            <Button Content="❌ Заброшено" Command="{Binding SelectAbandonedCommand}" Width="100" Margin="5" Padding="8,4"/>
        </StackPanel>

        <!-- Сетка книг текущего списка -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Books}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="200" ItemHeight="360"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White" Margin="10" Padding="10">
                            <StackPanel>
                                <Image Source="{Binding ImageUrl}" Height="180" Stretch="UniformToFill" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40"/>
                                <TextBlock Text="{Binding AuthorName}" Foreground="#6B7280" FontSize="12" Margin="0,5,0,10"/>
                                <!-- Кнопки изменения статуса книги -->
                                <StackPanel>
                                    <Button Content="📖 Читаю" Command="{Binding DataContext.MoveToReadingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" Width="150" Height="25" Margin="0,0,0,5" Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="✅ Завершить" Command="{Binding DataContext.MoveToFinishedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" Width="150" Height="25" Margin="0,0,0,5" Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="❌ Забросить" Command="{Binding DataContext.MoveToAbandonedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" Width="150" Height="25" Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>