<UserControl x:Class="up.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">
    <Grid Margin="20">
        <!-- Основной контрол с вкладками для разделов администрирования -->
        <TabControl>
            <!-- 1. Вкладка управления пользователями -->
            <TabItem Header=" Пользователи">
                <!-- Таблица пользователей с возможностью изменения роли, пароля и заморозки -->
                <DataGrid ItemsSource="{Binding UsersList}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                        <DataGridTextColumn Header="Никнейм" Binding="{Binding Nickname}" Width="150"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Roles.RoleName}" Width="120"/>
                        <DataGridTextColumn Header="Заморожен" Binding="{Binding IsFrozen}" Width="80"/>
                        <!-- Колонка с кнопками действий -->
                        <DataGridTemplateColumn Header="Действия" Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="🔄 Роль" Command="{Binding DataContext.ChangeRoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Margin="0,0,5,0" Padding="5"/>
                                        <Button Content="🔑 Пароль" Command="{Binding DataContext.ChangePasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Margin="0,0,5,0" Padding="5"/>
                                        <Button Content="❄️/☀️" Command="{Binding DataContext.ToggleUserFreezeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Padding="5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- 2. Вкладка заявок на роль автора -->
            <TabItem Header="️ Заявки на роль">
                <DataGrid ItemsSource="{Binding RoleAppsList}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding Users.Nickname}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                        <!-- Кнопки принятия/отклонения -->
                        <DataGridTemplateColumn Header="Действия" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✅ Принять" Command="{Binding DataContext.ApproveRoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Margin="0,0,5,0" Background="#10B981" Foreground="White" Padding="5"/>
                                        <Button Content="❌ Отклонить" Command="{Binding DataContext.RejectRoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Background="#EF4444" Foreground="White" Padding="5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- 3. Вкладка заявок на разморозку (пользователи/книги) -->
            <TabItem Header=" Заявки на разморозку">
                <DataGrid ItemsSource="{Binding UnfreezeAppsList}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                        <DataGridTextColumn Header="От кого" Binding="{Binding Users.Nickname}" Width="120"/>
                        <DataGridTextColumn Header="Тип цели" Binding="{Binding TargetTypeId}" Width="100"/>
                        <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                        <DataGridTemplateColumn Header="Действия" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✅ Принять" Command="{Binding DataContext.ApproveUnfreezeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Margin="0,0,5,0" Background="#10B981" Foreground="White" Padding="5"/>
                                        <Button Content="❌ Отклонить" Command="{Binding DataContext.RejectUnfreezeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Background="#EF4444" Foreground="White" Padding="5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- 4. Вкладка замороженных объектов (книги и пользователи) -->
            <TabItem Header="❄️ Замороженные">
                <!-- Вложенные вкладки для книг и пользователей -->
                <TabControl>
                    <TabItem Header="📚 Книги">
                        <DataGrid ItemsSource="{Binding FrozenBooksList}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Название" Binding="{Binding BookName}" Width="*"/>
                                <DataGridTextColumn Header="Автор" Binding="{Binding Users.Nickname}" Width="150"/>
                                <DataGridTemplateColumn Header="Действия" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="️ Разморозить" Command="{Binding DataContext.UnfreezeBookCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Background="#3B82F6" Foreground="White" Padding="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="👤 Пользователи">
                        <DataGrid ItemsSource="{Binding FrozenUsersList}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="150"/>
                                <DataGridTextColumn Header="Никнейм" Binding="{Binding Nickname}" Width="150"/>
                                <DataGridTextColumn Header="Роль" Binding="{Binding Roles.RoleName}" Width="120"/>
                                <DataGridTemplateColumn Header="Действия" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="️ Разморозить" Command="{Binding DataContext.UnfreezeUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding ID}" Background="#3B82F6" Foreground="White" Padding="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- 5. Вкладка жалоб -->
            <TabItem Header="🚩 Жалобы">
                <DataGrid ItemsSource="{Binding ComplaintsList}" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                        <DataGridTextColumn Header="Жалобщик" Binding="{Binding Users.Nickname}" Width="120"/>
                        <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                        <!-- Кнопка принятия мер по жалобе -->
                        <DataGridTemplateColumn Header="Действия" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content=" Принять меру" 
                                            Command="{Binding DataContext.HandleComplaintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding ID}" 
                                            Background="#F59E0B" Foreground="White" Padding="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>