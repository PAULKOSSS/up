<UserControl x:Class="up.Views.AuthorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:up.Infrastructure"
             Background="#F9FAFB">

    <UserControl.Resources>
        <!-- Конвертер для скрытия/показа элементов по bool свойству -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель: заголовок и кнопка добавления книги -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Управление книгами" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="➕ Добавить новую книгу" Command="{Binding AddBookCommand}" 
                    Background="#3B82F6" Foreground="White" Padding="12,8" BorderThickness="0" Cursor="Hand" FontSize="14"/>
        </StackPanel>

        <!-- Вкладки: все книги и замороженные -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- Вкладка со всеми книгами автора -->
            <TabItem Header=" Все мои книги" FontSize="14" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding AllBooks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="220" ItemHeight="340"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White" Margin="10" Padding="10">
                                    <StackPanel>
                                        <Image Source="{Binding ImageUrl}" Height="180" Stretch="UniformToFill" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40"/>
                                        <TextBlock Text="{Binding AuthorName}" Foreground="#6B7280" FontSize="12" Margin="0,5,0,5"/>
                                        <!-- Бейдж заморозки -->
                                        <Border Background="#FEE2E2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="4" Padding="6,4" 
                                                HorizontalAlignment="Left" Margin="0,5,0,0"
                                                Visibility="{Binding IsFrozen, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="❄️ Заморожена" FontSize="11" FontWeight="SemiBold" Foreground="#991B1B"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка с замороженными книгами (отдельная) -->
            <TabItem Header="❄️ Замороженные" FontSize="14" FontWeight="SemiBold">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Здесь отображаются книги, заблокированные администратором. Вы можете оспорить заморозку." 
                               Foreground="#6B7280" FontSize="13" Margin="0,0,0,15" TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding FrozenBooks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="220" ItemHeight="360"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Красная рамка и желтый фон для замороженных книг -->
                                <Border BorderBrush="#FCA5A5" BorderThickness="2" CornerRadius="8" Background="#FFFBEB" Margin="10" Padding="10">
                                    <StackPanel>
                                        <Image Source="{Binding ImageUrl}" Height="180" Stretch="UniformToFill" Margin="0,0,0,10" Opacity="0.8"/>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40" Foreground="#991B1B"/>
                                        <TextBlock Text="{Binding AuthorName}" Foreground="#7F1D1D" FontSize="12" Margin="0,5,0,10"/>
                                        <!-- Кнопка оспаривания заморозки -->
                                        <Button Content="📩 Оспорить заморозку" 
                                                Command="{Binding DataContext.AppealBookFreezeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" 
                                                Width="180" Height="32" 
                                                Background="#EF4444" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="12"
                                                HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Сообщение, если замороженных книг нет -->
                    <TextBlock Text="Нет замороженных книг ✅" 
                               Foreground="#10B981" FontSize="14" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FrozenBooks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>