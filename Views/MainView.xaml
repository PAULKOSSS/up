<UserControl x:Class="up.Views.MainView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:views="clr-namespace:up.Views"
      xmlns:vm="clr-namespace:up.ViewModels"
      Background="#F5F7FA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- DataTemplate'ы связывают ViewModel с соответствующими View -->
        <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
            <views:CatalogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookListsViewModel}">
            <views:BookListsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <views:ProfileView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuthorViewModel}">
            <views:AuthorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminViewModel}">
            <views:AdminView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookDetailViewModel}">
            <views:BookDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookEditorViewModel}">
            <views:BookEditorView/>
        </DataTemplate>

        <!-- Стили для кнопок бокового меню -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTipService.ShowDuration" Value="3000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Стиль для иконок в виде Path -->
        <Style x:Key="IconStyle" TargetType="Path">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Fill" Value="#374151"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню (Sidebar) с иконками и всплывающими подсказками -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                <!-- Администрирование (видно только администратору) -->
                <Button Style="{StaticResource SidebarButtonStyle}" 
                    Command="{Binding NavigateAdminCommand}"
                    ToolTip="Администрирование"
                    Visibility="{Binding ShowAdmin, Converter={StaticResource BoolToVis}}">
                    <Path Style="{StaticResource IconStyle}" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
                </Button>
                <!-- Страница автора (видно только автору) -->
                <Button Style="{StaticResource SidebarButtonStyle}" 
                    Command="{Binding NavigateAuthorCommand}"
                    ToolTip="Страница автора"
                    Visibility="{Binding ShowAuthor, Converter={StaticResource BoolToVis}}">
                    <Path Style="{StaticResource IconStyle}" Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </Button>
                <!-- Профиль (всегда) -->
                <Button Style="{StaticResource SidebarButtonStyle}" 
                    Command="{Binding NavigateProfileCommand}"
                    ToolTip="Профиль">
                    <Path Style="{StaticResource IconStyle}" Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </Button>
                <!-- Каталог книг -->
                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateCatalogCommand}" ToolTip="Каталог книг">
                    <Path Style="{StaticResource IconStyle}" Data="M3 4h18v2H3V4zm0 4h18v2H3V8zm0 4h12v2H3v-2zm0 4h18v2H3v-2z"/>
                </Button>
                <!-- Списки книг -->
                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateListsCommand}" ToolTip="Списки книг">
                    <Path Style="{StaticResource IconStyle}" Data="M4 6h16v2H4V6zm0 4h10v2H4v-2zm0 4h14v2H4v-2zm0 4h8v2H4v-2z"/>
                </Button>
                <!-- Выход из системы -->
                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding LogoutCommand}" ToolTip="Выйти">
                    <Path Style="{StaticResource IconStyle}" Data="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Область отображения текущего содержимого (меняется через ContentControl) -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</UserControl>